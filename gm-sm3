#!/usr/bin/env python3
"""GMKit SM3 CLI."""

from __future__ import annotations

import argparse
import base64
import sys
from pathlib import Path

from gmcrypto_core import sm3_hash


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(prog="gm-sm3", description="Calculate SM3 digests.")
    parser.add_argument("--in", dest="input_path", help="Input file. Defaults to stdin.")
    parser.add_argument("--out", dest="output_path", help="Output file. Defaults to stdout.")
    parser.add_argument(
        "--format",
        choices=("hex", "base64", "binary"),
        default="hex",
        help="Digest output format. Default: hex",
    )
    return parser


def encode_digest(digest: bytes, output_format: str) -> bytes:
    if output_format == "hex":
        return digest.hex().encode("ascii") + b"\n"
    if output_format == "base64":
        return base64.b64encode(digest) + b"\n"
    if output_format == "binary":
        return digest
    raise ValueError(f"unsupported output format: {output_format}")


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)

    try:
        data = Path(args.input_path).read_bytes() if args.input_path else sys.stdin.buffer.read()
        output = encode_digest(sm3_hash(data), args.format)
        if args.output_path:
            Path(args.output_path).write_bytes(output)
            print(f"wrote {args.output_path}")
        else:
            sys.stdout.buffer.write(output)
    except OSError as exc:
        parser.exit(2, f"gm-sm3: error: {exc}\n")
    except ValueError as exc:
        parser.exit(2, f"gm-sm3: error: {exc}\n")

    return 0


if __name__ == "__main__":
    sys.exit(main())
